{
  "name": "@framersai/agentos-demo-automation",
  "version": "0.1.0",
  "private": true,
  "description": "Automated demo recording system for AgentOS Workbench",
  "scripts": {
    "record": "tsx run.ts",
    "record:all": "tsx run.ts --all",
    "record:streaming": "tsx run.ts --demo streaming",
    "record:agency": "tsx run.ts --demo agency",
    "record:personas": "tsx run.ts --demo personas",
    "record:workflows": "tsx run.ts --demo workflows",
    "record:telemetry": "tsx run.ts --demo telemetry",
    "record:themes": "tsx run.ts --demo themes",
    "record:evaluation": "tsx run.ts --demo evaluation",
    "record:export": "tsx run.ts --demo export-import",
    "record:4k": "tsx run.ts --width 3840 --height 2160",
    "record:1440p": "tsx run.ts --width 2560 --height 1440",
    "process": "tsx lib/video-processor.ts",
    "setup": "playwright install chromium"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "openai": "^4.0.0",
    "playwright": "^1.48.0"
  },
  "devDependencies": {
    "@types/ffmpeg-static": "^5.1.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
